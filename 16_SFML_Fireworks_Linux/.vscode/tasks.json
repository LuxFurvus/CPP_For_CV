{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with SFML",
            "type": "shell",
            "command": "/usr/bin/g++",
            "args": [
                "-std=c++23",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-I/usr/include",                // if SFML is installed here
                "-L/usr/lib",                     // adjust if libs live elsewhere
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
