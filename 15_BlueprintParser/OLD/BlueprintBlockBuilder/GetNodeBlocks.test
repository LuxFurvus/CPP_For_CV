#pragma once

#include "../BlueprintBlockBuilder/BlueprintBlockBuilder.h"
////////
#include <string>
#include <vector>
////////
#include <gtest/gtest.h>
////////


struct GetNodeBlocks : public BlueprintBlockBuilder
{
    static auto Call(const std::string_view FullBlueprintText)
    {
        return BlueprintBlockBuilder::GetNodeBlocks(FullBlueprintText);
    }
};


TEST(BlueprintBlockBuilder, T01_SuperSimpleBlueprint)
{
    SCOPED_TRACE("T01: "
        "IF: Basic blueprint with 2 valid blocks, "
        "THEN: Both are extracted");

    const std::string_view BlueprintText = R"TESTZ(
        Begin Object: CustomProperties Pin1, NodeGuid=1, FunctionReference=1 :End Object
        Begin Object: CustomProperties Pin2, NodeGuid=2, FunctionReference=2 :End Object
    )TESTZ";

    const std::vector<std::string> Result = GetNodeBlocks::Call(BlueprintText);

    ASSERT_EQ(Result.size(), 2u);
    EXPECT_EQ(Result[0], 
        "Begin Object: CustomProperties Pin1, NodeGuid=1, FunctionReference=1 :End Object");
    EXPECT_EQ(Result[1], 
        "Begin Object: CustomProperties Pin2, NodeGuid=2, FunctionReference=2 :End Object");
}

TEST(BlueprintBlockBuilder, T02_ExtractsTwoNodeBlocks)
{
    SCOPED_TRACE("T02: Full Blueprint text contains two Begin/End Object pairs");

    const std::string BlueprintText = R"BLUEPRINT(

Begin Object
    Class=/Script/BlueprintGraph.K2Node_FunctionEntry Name="K2Node_FunctionEntry_0" ExportPath="/Script/BlueprintGraph.K2Node_FunctionEntry'/Game/...'"
   FunctionReference=(MemberName="BpExampleFunc")
   NodeGuid=546E3B764F9A7281859A7492B0DD7672
   CustomProperties Pin (PinId=648922534AFB5D01DA7FEC8E15B1AD22, PinName="then", Direction="EGPD_Output", PinType.PinCategory="exec", ...)
End Object
Begin Object
    Class=/Script/BlueprintGraph.K2Node_FunctionResult Name="K2Node_FunctionResult_0" ExportPath="/Script/BlueprintGraph.K2Node_FunctionResult'/Game/...'"
   FunctionReference=(MemberName="BpExampleFunc")
   NodeGuid=2E07107941EA465F43EAEDB3B52902D9
   CustomProperties Pin (PinId=27C68A2940864649FB7DE4B6BD1C990A, PinName="execute", PinType.PinCategory="exec", ...)
End Object

)BLUEPRINT";

    const std::vector<std::string> Blocks = GetNodeBlocks::Call(BlueprintText);

    ASSERT_EQ(Blocks.size(), 2u);

    // First block checks
    EXPECT_TRUE(Blocks[0].contains("Begin Object"));
    EXPECT_TRUE(Blocks[0].contains("End Object"));
    EXPECT_TRUE(Blocks[0].contains("K2Node_FunctionEntry"));
    EXPECT_TRUE(Blocks[0].contains("CustomProperties Pin"));
    EXPECT_TRUE(Blocks[0].contains("NodeGuid="));
    EXPECT_TRUE(Blocks[0].contains("FunctionReference="));

    // Second block checks
    EXPECT_TRUE(Blocks[1].contains("Begin Object"));
    EXPECT_TRUE(Blocks[1].contains("End Object"));
    EXPECT_TRUE(Blocks[1].contains("K2Node_FunctionResult"));
    EXPECT_TRUE(Blocks[1].contains("CustomProperties Pin"));
    EXPECT_TRUE(Blocks[1].contains("NodeGuid="));
    EXPECT_TRUE(Blocks[1].contains("FunctionReference="));
}

TEST(BlueprintBlockBuilder, T03_SkipsBlocksWithoutEssentialMarkers)
{
    SCOPED_TRACE("T03: Block with missing essential marker is skipped");

    const std::string BlueprintText = R"BLUEPRINT(
Begin Object Class=/Script/BlueprintGraph.K2Node_Void Name="K2Node_Skipped"
   SomethingWithoutRequiredMarkers
End Object
Begin Object Class=/Script/BlueprintGraph.K2Node_FunctionEntry Name="K2Node_FunctionEntry_1"
   FunctionReference=(MemberName="ValidFunc")
   NodeGuid=11112222333344445555666677778888
   CustomProperties Pin (PinId=ABC, PinName="X", Direction="EGPD_Output", PinType.PinCategory="exec", ...)
End Object
)BLUEPRINT";

    const std::vector<std::string> Blocks = GetNodeBlocks::Call(BlueprintText);

    ASSERT_EQ(Blocks.size(), 1u);
    EXPECT_TRUE(Blocks[0].find("K2Node_FunctionEntry_1") != std::string::npos);
    EXPECT_TRUE(Blocks[0].find("ValidFunc") != std::string::npos);
    EXPECT_TRUE(Blocks[0].find("NodeGuid=") != std::string::npos);
}

TEST(BlueprintBlockBuilder, T04_EmptyInputReturnsEmpty)
{
    SCOPED_TRACE("T04: Empty input results in no blocks");

    const std::string BlueprintText = "";

    const std::vector<std::string> Blocks = GetNodeBlocks::Call(BlueprintText);

    EXPECT_TRUE(Blocks.empty());
}

TEST(BlueprintBlockBuilder, T05_SingleIncompleteBlockIgnored)
{
    SCOPED_TRACE("T05: Only Begin Object present, missing End Object");

    const std::string BlueprintText = R"BLUEPRINT(
Begin Object Class=/Script/BlueprintGraph.K2Node_Incomplete Name="BrokenNode"
   FunctionReference=(MemberName="BrokenFunc")
   NodeGuid=00001111222233334444555566667777
   CustomProperties Pin (PinId=XYZ, PinName="Broken", Direction="EGPD_Output", PinType.PinCategory="exec", ...)
)BLUEPRINT";

    const std::vector<std::string> Blocks = GetNodeBlocks::Call(BlueprintText);

    EXPECT_TRUE(Blocks.empty());
}

