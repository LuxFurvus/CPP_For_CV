#pragma once

#include "../BlueprintBlockBuilder/BlueprintBlockBuilder.h"
////////
#include <string>
#include <vector>
////////
#include <gtest/gtest.h>
////////


struct GetCustomPropertiesBlocks : public BlueprintBlockBuilder
{
    static auto Call(const std::string_view FullBlueprintText)
    {
        return BlueprintBlockBuilder::GetCustomPropertiesBlocks(FullBlueprintText);
    }
};


TEST(GetCustomPropertiesBlocks, T01_SuperSimpleCustomProperties)
{
    SCOPED_TRACE("T01: "
        "IF: Basic CustomProperties with 3 valid blocks, "
        "THEN: All are extracted");

    const std::string_view BlueprintText = R"TESTZ(
        CustomProperties PinName=0", "PinType=0", " )
        CustomProperties PinName=1", "PinType=1", " )
        CustomProperties PinName=2", "PinType=2", " )
    )TESTZ";

    const std::vector<std::string> Result = GetCustomPropertiesBlocks::Call(BlueprintText);

    const size_t ExpectedSize = 3u;
    ASSERT_EQ(Result.size(), ExpectedSize);

    const std::string_view Expected0
        = R"TESTZ(CustomProperties PinName=0", "PinType=0", " ))TESTZ";
    EXPECT_TRUE(Result[0].contains(Expected0));

    const std::string_view Expected1
        = R"TESTZ(CustomProperties PinName=1", "PinType=1", " ))TESTZ";
    EXPECT_TRUE(Result[1].contains(Expected1));

    const std::string_view Expected2
        = R"TESTZ(CustomProperties PinName=2", "PinType=2", " ))TESTZ";
    EXPECT_TRUE(Result[2].contains(Expected2));
}

TEST(GetCustomPropertiesBlocks, T02_CustomPropertiesWithBrackets)
{
    SCOPED_TRACE("T02: "
        "IF: Basic CustomProperties with 3 valid blocks AND brackets(), "
        "THEN: All are extracted");

    const std::string_view BlueprintText = R"TESTZ(
        CustomProperties PinName=(0)", "PinType=(0)", " )
        CustomProperties PinName=(1)", "PinType=(1)", " )
        CustomProperties PinName=(2)", "PinType=(2)", " )
    )TESTZ";

    const std::vector<std::string> Result = GetCustomPropertiesBlocks::Call(BlueprintText);

    const size_t ExpectedSize = 3u;
    ASSERT_EQ(Result.size(), ExpectedSize);

    const std::string_view Expected0
        = R"TESTZ(CustomProperties PinName=(0)", "PinType=(0)", " ))TESTZ";
    EXPECT_TRUE(Result[0].contains(Expected0));

    const std::string_view Expected1
        = R"TESTZ(CustomProperties PinName=(1)", "PinType=(1)", " ))TESTZ";
    EXPECT_TRUE(Result[1].contains(Expected1));

    const std::string_view Expected2
        = R"TESTZ(CustomProperties PinName=(2)", "PinType=(2)", " ))TESTZ";
    EXPECT_TRUE(Result[2].contains(Expected2));
}

TEST(GetCustomPropertiesBlocks, T03_RealCustomProperties)
{
    SCOPED_TRACE("T03: "
        "IF: Real CustomProperties with 3 valid blocks, "
        "THEN: All are extracted");

    const std::string_view BlueprintText = R"TESTZ(
        NodeGuid=2E07107941EA465F43EAEDB3B52902D9
        CustomProperties Pin (PinId=27C68A2940864649FB7DE4B6BD1C990A,PinName="execute",PinType.PinCategory="exec",PinType.PinSubCategory="",PinType.PinSubCategoryObject=None,PinType.PinSubCategoryMemberReference=(),PinType.PinValueType=(),PinType.ContainerType=None,PinType.bIsReference=False,PinType.bIsConst=False,PinType.bIsWeakPointer=False,PinType.bIsUObjectWrapper=False,PinType.bSerializeAsSinglePrecisionFloat=False,LinkedTo=(K2Node_FunctionEntry_0 648922534AFB5D01DA7FEC8E15B1AD22,),PersistentGuid=00000000000000000000000000000000,bHidden=False,bNotConnectable=False,bDefaultValueIsReadOnly=False,bDefaultValueIsIgnored=False,bAdvancedView=False,bOrphanedPin=False,)
        CustomProperties Pin (PinId=5E4FE3EE4A61B5CD6B9E22B69340709C,PinName="PinOut",PinType.PinCategory="int",PinType.PinSubCategory="",PinType.PinSubCategoryObject=None,PinType.PinSubCategoryMemberReference=(),PinType.PinValueType=(),PinType.ContainerType=None,PinType.bIsReference=False,PinType.bIsConst=False,PinType.bIsWeakPointer=False,PinType.bIsUObjectWrapper=False,PinType.bSerializeAsSinglePrecisionFloat=False,DefaultValue="0",AutogeneratedDefaultValue="0",LinkedTo=(K2Node_PromotableOperator_0 84BA7F39461ECC56886E86AD8F6960B5,),PersistentGuid=00000000000000000000000000000000,bHidden=False,bNotConnectable=False,bDefaultValueIsReadOnly=False,bDefaultValueIsIgnored=False,bAdvancedView=False,bOrphanedPin=False,)
        CustomProperties UserDefinedPin (PinName="PinOut",PinType=(PinCategory="int"),DesiredPinDirection=EGPD_Input,PinDefaultValue="0")
        End Object
    )TESTZ";

    const std::vector<std::string> Result = GetCustomPropertiesBlocks::Call(BlueprintText);

    const size_t ExpectedSize = 3;
    ASSERT_EQ(Result.size(), ExpectedSize);

    EXPECT_TRUE(Result[0].contains("CustomProperties"));
    EXPECT_TRUE(Result[0].contains("27C68A2940864649FB7DE4B6BD1C990A"));
    EXPECT_TRUE(Result[0].contains("LinkedTo=(K2Node_FunctionEntry_0 648922534AFB5D01DA7FEC8E15B1AD22"));
    EXPECT_TRUE(Result[0].contains("PinCategory=\"exec\""));

    EXPECT_TRUE(Result[1].contains("CustomProperties"));
    EXPECT_TRUE(Result[1].contains("5E4FE3EE4A61B5CD6B9E22B69340709C"));
    EXPECT_TRUE(Result[1].contains("LinkedTo=(K2Node_PromotableOperator_0 84BA7F39461ECC56886E86AD8F6960B5"));
    EXPECT_TRUE(Result[1].contains("PinCategory=\"int\""));

    EXPECT_TRUE(Result[2].contains("CustomProperties"));
    EXPECT_TRUE(Result[2].contains("UserDefinedPin"));
    EXPECT_TRUE(Result[2].contains("DesiredPinDirection=EGPD_Input,"));
    EXPECT_TRUE(Result[2].contains("PinDefaultValue"));
}
