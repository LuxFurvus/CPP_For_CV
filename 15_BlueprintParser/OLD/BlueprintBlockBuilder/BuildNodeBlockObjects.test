#pragma once

#include "../BlueprintBlockBuilder/BlueprintBlockBuilder.h"
////////
#include <string>
#include <vector>
////////
#include <gtest/gtest.h>
////////


struct BuildNodeBlockObjects : public BlueprintBlockBuilder
{
    static auto Call(const std::string_view FullBlueprintText)
    {
        return BlueprintBlockBuilder::BuildNodeBlockObjects(FullBlueprintText);
    }
};


TEST(BuildNodeBlockObjects, T01_SuperSimpleBlueprintObjecBlocks)
{
    SCOPED_TRACE("T01: "
        "IF: Basic blueprint with 2 object blocks, "
        "THEN: Both are extracted");

    const std::string_view BlueprintText = R"TEXT(
        Begin Object0:
            Class=0", "ExportPath=0", "FunctionReference=0", "NodeGuid=0
            CustomProperties PinName=0(",) "PinType=0", " )
            CustomProperties PinName=1", "PinType=1", " )
            CustomProperties PinName=2", "PinType=2", " )
        :End Object
        Begin Object1:
            Class=1", "ExportPath=1", "FunctionReference=1", "NodeGuid=1
            CustomProperties PinName=0(",) "PinType=0", " )
            CustomProperties PinName=1", "PinType=1", " )
            CustomProperties PinName=2", "PinType=2", " )
        :End Object
    )TEXT";

    const std::vector<FBlueprintNodeBlocks> Result
        = BuildNodeBlockObjects::Call(BlueprintText);

    const size_t ExpectedNumOfBlocks = 2;
    ASSERT_EQ(Result.size(), ExpectedNumOfBlocks);

    EXPECT_TRUE(Result[0].IsValid());
    EXPECT_TRUE(Result[1].IsValid());
}

