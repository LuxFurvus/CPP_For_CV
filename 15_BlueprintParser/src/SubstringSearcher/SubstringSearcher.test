
#include "../SubstringExtractor/SubstringExtractor.h"
////////
#include <string>
#include <optional>
#include <utility>
////////
#include <gtest/gtest.h>
////////
#include "../SubstringSearcher/SubstringSearcher.h"


const auto FindSubstringRangeLambdaNEW = [](const FSubstringLookupTask& Task)
{
    auto CallSomeProtected = [](const std::string_view Text, const FSubstringRange& Range) {
        struct Local : public SubstringExtractor {
            auto Call(const std::string_view Text, const FSubstringRange& Range) {
                return this->ExtractSubstringByRange(Text, Range);
            }
        };
        return Local().Call(Text, Range);
    };

    const auto [Range, MatchedString] = SubstringSearcher::FindSubtringRangeByRules(Task);

    const std::optional<std::string> ExtractedSubstring = CallSomeProtected(Task.Text, Range);

    return std::pair<FSubstringRange, std::optional<std::string>>(Range, ExtractedSubstring);
};


TEST(SubstringSearcher_FindSubstringRange_Preconditions, T01_FSubstringRange_DefaultInvalidState)
{
    SCOPED_TRACE("T01: FSubstringRange is invalid and contains std::string::npos by default");
    FSubstringRange Range;
    EXPECT_TRUE(!Range.IsValid());
    EXPECT_EQ(Range.Start, std::string::npos);
    EXPECT_EQ(Range.End, std::string::npos);
}

TEST(SubstringSearcher_FindSubstringRange, T01_BasicMatch_NoIgnoredRules)
{
    SCOPED_TRACE("T01: Simple substring match without any ignored rules");

    FSubstringLookupTask Task {
        .Text = "abcdef",
        .Candidates = { "cde" },
        .Rules = FIgnoredRangesRules{},
        .StartLookupAt = 0,
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 2);
    EXPECT_EQ(Range.End, 5);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "cde");
}

TEST(SubstringSearcher_FindSubstringRange, T02_CaseInsensitiveMatch)
{
    SCOPED_TRACE("T02: Match with case-insensitive setting");

    FSubstringLookupTask Task {
        .Text = "AbCdEf",
        .Candidates = { "CDE" },
        .Rules = FIgnoredRangesRules {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = {},
            .bCaseInsensitive = true
        },
        .StartLookupAt = 0,
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 2);
    EXPECT_EQ(Range.End, 5);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "CdE");
}

TEST(SubstringSearcher_FindSubstringRange, T03_SubstringNotFound)
{
    SCOPED_TRACE("T03: Substring is not present");

    FSubstringLookupTask Task {
        .Text = "abcdef",
        .Candidates = { "xyz" },
        .Rules = FIgnoredRangesRules{},
        .StartLookupAt = 0,
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

TEST(SubstringSearcher_FindSubstringRange, T04_MatchWithIgnoredChars)
{
    SCOPED_TRACE("T04: Ignore specific characters during comparison");

    FSubstringLookupTask Task {
        .Text = "a_b_c_d_e",
        .Candidates = { "abcde" },
        .Rules = FIgnoredRangesRules {
            .IgnoredChar = [](char Ch) { return Ch == '_'; },
            .IgnoredRangesBetween = {},
            .bCaseInsensitive = false
        },
        .StartLookupAt = 0,
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 9);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "a_b_c_d_e");
}

TEST(SubstringSearcher_FindSubstringRange, T05_MatchInsideIgnoredRange_ShouldSkip)
{
    SCOPED_TRACE("T05: Substring occurs inside ignored range and should be skipped");

    FSubstringLookupTask Task {
        .Text = "abc(def)ghi",
        .Candidates = { "def" },
        .Rules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

TEST(SubstringSearcher_FindSubstringRange, T06_MatchAfterIgnoredRange)
{
    SCOPED_TRACE("T06: Substring appears after ignored range, should match correctly");

    FSubstringLookupTask Task {
        .Text = "abc(def)ghi",
        .Candidates = { "ghi" },
        .Rules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 8);
    EXPECT_EQ(Range.End, 11);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "ghi");
}

TEST(SubstringSearcher_FindSubstringRange, T07_EmptyText)
{
    SCOPED_TRACE("T07: Handle empty input text");

    FSubstringLookupTask Task {
        .Text = "",
        .Candidates = { "abc" },
        .Rules = {}
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

TEST(SubstringSearcher_FindSubstringRange, T08_EmptySubstring)
{
    SCOPED_TRACE("T08: Handle empty substring input");

    FSubstringLookupTask Task {
        .Text = "abcdef",
        .Candidates = { "" },
        .Rules = {}
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
