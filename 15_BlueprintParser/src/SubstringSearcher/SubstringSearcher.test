TEST(SubstringSearcher_FindSubstringRange, T17_NestedDifferentIgnoredPairs)
{
    SCOPED_TRACE("T17: Multiple different ignored range types should be skipped");

    FSubstringLookupTask Task {
        .Text = "a([x])bc",
        .Candidates = { "bc" },
        .Rules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'}, {'[', ']'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 6);
    EXPECT_EQ(Range.End, 8);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "bc");
}

TEST(SubstringSearcher_FindSubstringRange, T18_SubstringSplitByIgnoredRangeShouldNotMatch)
{
    SCOPED_TRACE("T18: Substring spanning ignored range should not match");

