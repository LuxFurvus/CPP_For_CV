TEST(SubstringSearcher_FindSubstringRange, T20_TextNormalizedAwayCompletely)
{
    SCOPED_TRACE("T20: Entire input removed by normalization — no match possible");

    FSubstringLookupTask Task {
        .Text = "(abc)",
        .Candidates = { "a" },
        .Rules = {
            .IgnoredChar = [](char) { return true; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

TEST(SubstringSearcher_FindSubstringRange, T21_OverlappinIgnoreBlocks)
{
    SCOPED_TRACE("T21: Two overlapping ignored blocks, must parse");

    FSubstringLookupTask Task {
        .Text = R"TEXT(sometext(")" <-- issue is here!!!abc)TEXT",
        .Candidates = { "abc" },
        .Rules = {
            .IgnoredRangesBetween = { {'(', ')'}, {'"', '"'} },
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    ASSERT_TRUE(Extracted.has_value());

    std::string Expected = "abc";
    EXPECT_EQ(*Extracted, Expected);
}

