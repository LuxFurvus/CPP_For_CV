TEST(SubstringSearcher_FindSubstringRange, T09_SubstringAcrossIgnoredRange_ShouldNotMatch)
{
    SCOPED_TRACE("T09: Substring partially inside ignored range should not match");

    FSubstringLookupTask Task {
        .Text = "ab[cd]efg",
        .Candidates = { "cdef" },
        .Rules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'[', ']'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

TEST(SubstringSearcher_FindSubstringRange, T10_SubstringWrappedWithIgnoredRange_ShouldMatch)
{
    SCOPED_TRACE("T10: Match ignoring wrapped content");

    FSubstringLookupTask Task {
        .Text = "a_(B)[x]C_D",
        .Candidates = { "ACD" },
        .Rules = {
            .IgnoredChar = [](char Ch) { return Ch == '_'; },
            .IgnoredRangesBetween = { {'(', ')'}, {'[', ']'} },
            .bCaseInsensitive = true
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 11);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "a_(B)[x]C_D");
}

TEST(SubstringSearcher_FindSubstringRange, T11_RepeatedIgnoredRangesHandledCorrectly)
{
    SCOPED_TRACE("T11: Multiple ignored ranges sequentially must not affect final match");

    FSubstringLookupTask Task {
        .Text = R"(a("1")("2")bcd)",
        .Candidates = { "bcd" },
        .Rules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'}, {'"', '"'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 11);
    EXPECT_EQ(Range.End, 14);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "bcd");
}

TEST(SubstringSearcher_FindSubstringRange, T12_FullMatchAfterNormalization)
{
    SCOPED_TRACE("T12: Entire string matches after ignoring chars and ranges and lowering case");

    FSubstringLookupTask Task {
        .Text = "A_B(C)D",
        .Candidates = { "abd" },
        .Rules = {
            .IgnoredChar = [](char Ch) { return Ch == '_'; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = true
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 7);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "A_B(C)D");
}

TEST(SubstringSearcher_FindSubstringRange, T13_StartsImmediatelyAfterIgnoredRange)
{
    SCOPED_TRACE("T13: Match should begin right after an ignored range block");

    FSubstringLookupTask Task {
        .Text = "(x)abcde",
        .Candidates = { "abc" },
        .Rules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 3);
    EXPECT_EQ(Range.End, 6);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "abc");
}

TEST(SubstringSearcher_FindSubstringRange, T14_PartialRepeatingCharacters)
{
    SCOPED_TRACE("T14: Avoid partial match resets in repeated characters");

    FSubstringLookupTask Task {
        .Text = "aabbccddeeff",
        .Candidates = { "bbcc" },
        .Rules = {}
    };

    auto [Range, Extracted] = FindSubstringRangeLambdaNEW(Task);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 2);
    EXPECT_EQ(Range.End, 6);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "bbcc");
}

TEST(SubstringSearcher_FindSubstringRange, T15_UnclosedIgnoredRange)
{
    SCOPED_TRACE("T15: Unclosed ignored block skips to end of text");

    FSubstringLookupTask Task {
        .Text = "abc(def",
