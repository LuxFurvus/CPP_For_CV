
#include "../SubstringExtractor/SubstringExtractor.h"
////////
#include <string>
#include <vector>
#include <optional>
////////
#include <gtest/gtest.h>
////////

const auto ExtractAllByRules = [](
    const std::string_view Source,
    const FExtractionRules& Rules)
{
    return SubstringExtractor::ExtractAllSubstrings(Source, Rules);
};

TEST(SubstringExtractor_ExtractAllSubstrings, T01_MultipleBlocksPresent)
{
    SCOPED_TRACE("T01: "
        "IF: Two valid blocks enclosed by start/end markers, "
        "THEN: Both are extracted");

    const std::string Source = "Item=(Value=1) Extra Item=(Value=2)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char) { return false; },
            .bCaseInsensitive = false
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 2u);
    EXPECT_EQ(Result[0], "Item=(Value=1)");
    EXPECT_EQ(Result[1], "Item=(Value=2)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T02_SingleBlockPresent)
{
    SCOPED_TRACE("T02: "
        "IF: One valid block, "
        "THEN: One result returned");

    const std::string_view Source = "Item=(Data=42)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
        },
        .IgnoredRangesRules = {}
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 1u);
    EXPECT_EQ(Result[0], "Item=(Data=42)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T03_NoStartMarker)
{
    SCOPED_TRACE("T03: "
        "IF: No start marker exists in the text, "
        "THEN: No substring extracted");

    const std::string_view Source = "NoMatch=(X=Y)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "MissingStart=" },
            .EndMarkers = { ")" },
        },
        .IgnoredRangesRules = {}
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    EXPECT_TRUE(Result.empty());
}

TEST(SubstringExtractor_ExtractAllSubstrings, T04_OverlappingMarkersHandledSafely)
{
    SCOPED_TRACE("T04: "
        "IF: Nested blocks, "
        "THEN: Only top-level non-overlapping blocks are extracted");

    const std::string_view Source = "Block=[Inner=(X=Y)] Block=[Inner=(A=B)].";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Block=" },
            .EndMarkers = { "." },
        },
        .IgnoredRangesRules = {
            .IgnoredRangesBetween = { {'(', ')'} },
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    const size_t ExpectedResultSize = 1u;
    ASSERT_EQ(Result.size(), ExpectedResultSize);

    const std::string_view ExpectedResult0 = Source;
    EXPECT_EQ(Result[0], ExpectedResult0);
}

TEST(SubstringExtractor_ExtractAllSubstrings, T05_RequiresEssentialMarkerInside)
{
    SCOPED_TRACE("T05: "
        "IF: Block exists but lacks essential marker inside, "
        "THEN: Block is skipped");

    const std::string_view Source = "Item=(ID=5) Item=(Name=Foo)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
            .EssentialMarkers = { "Name=" }
        },
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 1u);
    EXPECT_EQ(Result[0], "Item=(Name=Foo)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T06_EmptyInputReturnsEmpty)
{
    SCOPED_TRACE("T06: "
        "IF: Empty source, "
        "THEN: Result is empty");

    const std::string_view Source = "";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "X=" },
            .EndMarkers = { ")" },
        },
        .IgnoredRangesRules = {}
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    EXPECT_TRUE(Result.empty());
}

TEST(SubstringExtractor_ExtractAllSubstrings, T07_StartIsNpos_EssentialMarkerMissing)
{
    SCOPED_TRACE("T07: Start is npos, block skipped, next one processed");

    const std::string_view Source = "Item=(ID=1) Item=(Name=Valid)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
            .EssentialMarkers = { "Name=" }
        },
        .IgnoredRangesRules = {}
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 1u);
    EXPECT_EQ(Result[0], "Item=(Name=Valid)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T08_EndMarkerMissing)
{
    SCOPED_TRACE("T08: No End marker, block consumes all till theend marker");

    const std::string_view Source = "Item=(A=1 Item=(B=2)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

