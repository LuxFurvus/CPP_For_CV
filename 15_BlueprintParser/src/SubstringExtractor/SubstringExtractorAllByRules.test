TEST(SubstringExtractor_ExtractAllSubstrings, T09_ZeroLengthRange)
{
    SCOPED_TRACE("T09: Range with zero length is ignored");

    const std::string_view Source = "Item=";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    EXPECT_TRUE(Result.empty());
}

TEST(SubstringExtractor_ExtractAllSubstrings, T10_EndBeforeStart)
{
    SCOPED_TRACE("T10: End marker before start marker, invalid");

    const std::string_view Source = "End Item=(A=1)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { "End" },
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    EXPECT_TRUE(Result.empty());
}

TEST(SubstringExtractor_ExtractAllSubstrings, T11_ConsecutiveValidBlocks)
{
    SCOPED_TRACE("T11: Consecutive blocks without whitespace are extracted");

    const std::string_view Source = "Item=(A=1)Item=(B=2)Item=(C=3)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 3u);
    EXPECT_EQ(Result[0], "Item=(A=1)");
    EXPECT_EQ(Result[1], "Item=(B=2)");
    EXPECT_EQ(Result[2], "Item=(C=3)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T12_NestedIgnoredRangesInsideBlock)
{
    SCOPED_TRACE("T12: Ignored nested range inside block does not break extraction");

    const std::string_view Source = "Item=(A=\"B,C\") Item=(D=E)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
        },
        .IgnoredRangesRules = {
            .IgnoredRangesBetween = { {'"', '"'} }
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 2u);
    EXPECT_EQ(Result[0], "Item=(A=\"B,C\")");
    EXPECT_EQ(Result[1], "Item=(D=E)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T13_CaseInsensitiveMarkers)
{
    SCOPED_TRACE("T13: Case-insensitive Start marker");

    const std::string_view Source = "ITEM=(X=1)item=(Y=2)Item=(Z=3)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "item=" },
            .EndMarkers = { ")" },
        },
        .IgnoredRangesRules = {
            .bCaseInsensitive = true
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 3u);
    EXPECT_EQ(Result[0], "ITEM=(X=1)");
    EXPECT_EQ(Result[1], "item=(Y=2)");
    EXPECT_EQ(Result[2], "Item=(Z=3)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T14_InvalidBlocksSkipped_ValidOnesPreserved)
{
    SCOPED_TRACE("T14: Invalid block without EssentialMarkers skipped, valid block extracted");

    const std::string_view Source = "Item=(A=1)zzzItem=(B=2)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
            .EssentialMarkers = { "B=" }
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 1u);
    EXPECT_EQ(Result[0], "Item=(B=2)");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T15_OnlyEndMarkersPresent)
{
    SCOPED_TRACE("T15: Only End markers exist, nothing extracted");

    const std::string_view Source = "End End End";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { "End" },
        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    EXPECT_TRUE(Result.empty());
}

TEST(SubstringExtractor_ExtractAllSubstrings, T16_RealBlueprintExample)
{
    SCOPED_TRACE("T16: "
        "IF: Basic blueprint with 2 valid blocks, "
        "THEN: Both are extracted");

    const std::string_view Source = R"TESTZ(
        Begin Object: CustomProperties Pin1, NodeGuid=1, MemberName=1 :End Object
        Begin Object: CustomProperties Pin2, NodeGuid=2, MemberName=2 :End Object
    )TESTZ";

    const FExtractionRules Rules {
        .BlockMarkers{
            .StartMarkers = { "Begin Object", "Class=", "ExportPath=", "FunctionReference=" },
            .EndMarkers = { "End Object" },
            .EssentialMarkers = {"CustomProperties Pin", "NodeGuid=", "MemberName="}
        },
        .IgnoredRangesRules
        {
            .IgnoredChar = [](char c) { return !isgraph(static_cast<unsigned char>(c)); },
            .IgnoredRangesBetween = { {'(', ')'}, {'"', '"'}, {'\'', '\''} },
            .bCaseInsensitive = true

        }
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 2u);
    EXPECT_EQ(Result[0], "Begin Object: CustomProperties Pin1, NodeGuid=1, MemberName=1 :End Object");
    EXPECT_EQ(Result[1], "Begin Object: CustomProperties Pin2, NodeGuid=2, MemberName=2 :End Object");
}

TEST(SubstringExtractor_ExtractAllSubstrings, T17_ExcludeMarkers_SingleBlock)
{
    SCOPED_TRACE("T17: "
        "IF: Single block with bExcludeMarkers=true, "
        "THEN: Only content between markers is extracted");

    const std::string_view Source = "Item=(Data=42)";
    const FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Item=" },
            .EndMarkers = { ")" },
        },
        .IgnoredRangesRules = {},
        .bExcludeMarkers = true
    };

    const auto Result = ExtractAllByRules(Source, Rules);

    ASSERT_EQ(Result.size(), 1u);
    EXPECT_EQ(Result[0], "(Data=42");
}

