//------------------------------------------------------------------------------
// ExtractFirstSubstring, T04_EssentialMarkerMissing
//------------------------------------------------------------------------------
TEST(ExtractFirstSubstring, T04_EssentialMarkerMissing)
{
    SCOPED_TRACE("T04: Essential marker not present between start and end");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" },
            .EssentialMarkers = { "KEY" }
        },
        .IgnoredRangesRules = {}
    };

    const std::string Text = "Start CONTENT End";

    auto [Range, Extracted] = RunExtractSubstringByRulesTests(Text, Rules);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

TEST(ExtractFirstSubstring, T05_EssentialMarkerPresent)
{
    SCOPED_TRACE("T05: Essential marker present and validated");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" },
            .EssentialMarkers = { "KEY" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start someKEYstuff End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 22);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start someKEYstuff End");
}

TEST(ExtractFirstSubstring, T05bis_EssentialMarkerPresentInSecondBlock)
{
    SCOPED_TRACE("T05bis: Essential marker present in second block");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" },
            .EssentialMarkers = { "SECOND" }
        },
        .IgnoredRangesRules = {}
    };

    const std::string Text = "Start FIRST EndxxxStart SECOND End";
    auto [Range, Extracted] = RunExtractSubstringByRulesTests(Text, Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 18);
    EXPECT_EQ(Range.End, 34);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start SECOND End");
}

TEST(ExtractFirstSubstring, T06_WithIgnoredRangesBetween)
{
    SCOPED_TRACE("T06: Ignore content inside () ranges during marker search");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start (SKIP) REAL End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 21);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start (SKIP) REAL End");
}

TEST(ExtractFirstSubstring, T07_MultipleStartMarkers_ChooseFirstValid)
{
    SCOPED_TRACE("T07: Multiple StartMarkers — choose first valid");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start", "Open" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Open block Start payload End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 11);
    EXPECT_EQ(Range.End, 28);
    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start payload End");
}

TEST(ExtractFirstSubstring, T08_MultipleEndMarkers_ChooseFirstValid)
{
    SCOPED_TRACE("T08: Multiple EndMarkers — choose first valid after start");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "Stop", "End" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start DATA Stop and then End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 15);
    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start DATA Stop");
}

TEST(ExtractFirstSubstring, T09_IgnoredCharDoesNotEliminateEssentials)
{
    SCOPED_TRACE("T09: IgnoredChar does not remove essential content");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" },
            .EssentialMarkers = { "abcde" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char Ch) { return Ch == '_'; },
            .IgnoredRangesBetween = {},
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start a_b_c_d_e End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 19);
    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start a_b_c_d_e End");
}

TEST(ExtractFirstSubstring, T10_NestedIgnoredRangesSkipped)
{
    SCOPED_TRACE("T10: Nested ignored ranges skipped during essential scan");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start ((ignore this)) End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 25);
    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start ((ignore this)) End");
}

TEST(ExtractFirstSubstring, T11_EndMarkerAtEndOfText)
{
    SCOPED_TRACE("T11: EndMarker is the last word in text");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start something to End!", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 22);
    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start something to End");
}

TEST(ExtractFirstSubstring, T12_MarkersInsideIgnoredRangeSkipped)
{
    SCOPED_TRACE("T12: Start marker inside ignored range should not be used");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("(Start) Start visible End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 8);
    EXPECT_EQ(Range.End, 25);
    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start visible End");
}

TEST(ExtractFirstSubstring, T13_EssentialMarkerMustBeOutsideIgnoredRange)
{
    SCOPED_TRACE("T13: Essential marker inside ignored range should be skipped");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" },
            .EssentialMarkers = { "KEY" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'(', ')'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start (KEY) visible End", Rules);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

TEST(ExtractFirstSubstring, T14_CaseInsensitiveMatching)
{
    SCOPED_TRACE("T14: Case-insensitive matching across all markers");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "START" },
            .EndMarkers = { "END" },
            .EssentialMarkers = { "key" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = {},
            .bCaseInsensitive = true
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("sTarT content Key EnD", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 21);
    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "sTarT content Key EnD");
}

