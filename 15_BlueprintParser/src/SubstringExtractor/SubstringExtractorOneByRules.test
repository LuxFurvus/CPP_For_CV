{
    SCOPED_TRACE("T20: All essential markers must be found");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" },
            .EssentialMarkers = { "A", "B", "C" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start A and C only End", Rules);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

//------------------------------------------------------------------------------
// ExtractSubstringByRules_Extended, T21_MarkersAtTextBounds
//------------------------------------------------------------------------------
TEST(ExtractSubstringByRules_Extended, T21_MarkersAtTextBounds)
{
    SCOPED_TRACE("T21: Start at 0, End at text.size()");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End!" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start full range End!", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 21);
    EXPECT_EQ(Extracted.value(), "Start full range End!");
}

//------------------------------------------------------------------------------
// ExtractSubstringByRules_Extended, T22_EmptyBlockContent
//------------------------------------------------------------------------------
TEST(ExtractSubstringByRules_Extended, T22_EmptyBlockContent)
{
    SCOPED_TRACE("T22: Block with empty content is invalid");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("StartEnd", Rules);

    EXPECT_TRUE(Range.IsValid() == false);
    EXPECT_EQ(Range.Start, std::string::npos);
    EXPECT_EQ(Range.End, std::string::npos);
    EXPECT_TRUE(!Extracted);
}

//------------------------------------------------------------------------------
// ExtractSubstringByRules_Extended, T23_BlockInsideIgnoredRange
//------------------------------------------------------------------------------
TEST(ExtractSubstringByRules_Extended, T23_BlockInsideIgnoredRange)
{
    SCOPED_TRACE("T23: Entire block inside ignored range should be skipped");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char) { return false; },
            .IgnoredRangesBetween = { {'<', '>'} },
            .bCaseInsensitive = false
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("<Start skip End>", Rules);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

//------------------------------------------------------------------------------
// ExtractSubstringByRules_Extended, T24_EmptyTextOrInvalidRules
//------------------------------------------------------------------------------
TEST(ExtractSubstringByRules_Extended, T24_EmptyTextOrInvalidRules)
{
    SCOPED_TRACE("T24: Empty text or missing markers");

    FExtractionRules InvalidRules {
        .BlockMarkers = {
            .StartMarkers = {},
            .EndMarkers = {}
        },
        .IgnoredRangesRules = {}
    };

    auto [RangeA, ExtractedA] = RunExtractSubstringByRulesTests("", InvalidRules);
    EXPECT_FALSE(RangeA.IsValid());
    EXPECT_FALSE(ExtractedA.has_value());

    auto [RangeB, ExtractedB] = RunExtractSubstringByRulesTests("Start X End", InvalidRules);
    EXPECT_FALSE(RangeB.IsValid());
    EXPECT_FALSE(ExtractedB.has_value());
}

TEST(ExtractSubstringByRules_Extended, T25_CharIgnorePlusCaseInsensitive)
{
    SCOPED_TRACE("T25: Char ignoring and case-insensitivity together");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "START" },
            .EndMarkers = { "END" },
            .EssentialMarkers = { "key" }
        },
        .IgnoredRangesRules = {
            .IgnoredChar = [](char C) { return C == '_'; },
            .IgnoredRangesBetween = {},
            .bCaseInsensitive = true
        }
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("s_T_A_R_T _key_ e_N_D", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Extracted.value(), "s_T_A_R_T _key_ e_N_D");
}

TEST(ExtractSubstringByRules, T26_OverlappinIgnoreBlocks)
{
    SCOPED_TRACE("T26: Two overlapping ignored blocks, must parse");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Begin Object" },
            .EndMarkers = { "End Object" },
            .EssentialMarkers = {"CustomProperties Pin", "NodeGuid=", "FunctionReference="}
        },
        .IgnoredRangesRules = {
            .IgnoredRangesBetween = { {'(', ')'}, {'"', '"'} },
        }
    };

    const std::string_view BlueprintText
        = R"TESTZ(Begin Object:
            (")" <-- issue is here!!!
            CustomProperties Pin1, NodeGuid=1,
            FunctionReference=1 
        :End Object)TESTZ";

    auto [Range, Extracted] = RunExtractSubstringByRulesTests(BlueprintText, Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Extracted.value(), BlueprintText);
}
