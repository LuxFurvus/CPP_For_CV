//------------------------------------------------------------------------------
// ExtractSubstringByRules_Extended, T17_OverlappingMarkers_FirstEndWins
//------------------------------------------------------------------------------
TEST(ExtractSubstringByRules_Extended, T17_OverlappingMarkers_FirstEndWins)
{
    SCOPED_TRACE("T17: Overlapping start markers — first End after first Start wins");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start X Start Y End End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Extracted.value(), "Start X Start Y End");
}

