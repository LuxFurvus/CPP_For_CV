
#include "../SubstringExtractor/SubstringExtractor.h"
////////
#include <string>
#include <optional>
////////
#include <gtest/gtest.h>
////////
#include "../SubstringExtractor/BaseParseStructures.h"

const auto RunExtractSubstringByRulesTests = [](
    const std::string_view Text,
    const FExtractionRules& Rules)
{
    const auto [Range, Extracted]
        = SubstringExtractor::ExtractFirstSubstring(Text, Rules);

    return std::pair<FSubstringRange, std::optional<std::string>>(Range, Extracted);
};

//------------------------------------------------------------------------------
// ExtractFirstSubstring, T01_ValidSimpleBlock
//------------------------------------------------------------------------------
TEST(ExtractFirstSubstring, T01_ValidSimpleBlock)
{
    SCOPED_TRACE("T01: Basic block extraction with default rules, no ignores");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Start" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start CONTENT End", Rules);

    EXPECT_TRUE(Range.IsValid());
    EXPECT_EQ(Range.Start, 0);
    EXPECT_EQ(Range.End, 17);

    EXPECT_TRUE(Extracted.has_value());
    EXPECT_EQ(Extracted.value(), "Start CONTENT End");
}

//------------------------------------------------------------------------------
// ExtractFirstSubstring, T02_BlockMissingStartMarker
//------------------------------------------------------------------------------
TEST(ExtractFirstSubstring, T02_BlockMissingStartMarker)
{
    SCOPED_TRACE("T02: Block start marker not found");

    FExtractionRules Rules {
        .BlockMarkers = {
            .StartMarkers = { "Begin" },
            .EndMarkers = { "End" }
        },
        .IgnoredRangesRules = {}
    };

    auto [Range, Extracted] = RunExtractSubstringByRulesTests("Start CONTENT End", Rules);

    EXPECT_FALSE(Range.IsValid());
    EXPECT_FALSE(Extracted.has_value());
}

