<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/resultCardGeneral"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_result_card"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineResultMiddle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.34" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/valueResultsData"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="start|top"
            android:includeFontPadding="false"
            android:text="@string/data_empty"
            android:textIsSelectable="true"

            app:autoSizeMaxTextSize="150sp"
            app:autoSizeMinTextSize="5sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/guidelineResultMiddle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/panelResultsLowerPart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/guidelineResultMiddle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCleanResults"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/label_minus"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="8dp"
                app:backgroundTint="@color/screen_background"
                app:cornerRadius="22dp"
                app:elevation="6dp"
                app:icon="@drawable/x_clear"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/roll_button_text"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:pressedTranslationZ="10dp"
                app:rippleColor="@color/ripple_color" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/valueResultSum"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/data_empty"
                android:textIsSelectable="true"
                android:textStyle="bold"

                app:autoSizeMaxTextSize="500sp"
                app:autoSizeMinTextSize="5sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"

                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>