{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Module Test (WSL)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/${input:moduleName}.test",
      "args": [],
      "cwd": "${workspaceFolder}",
      "externalConsole": false,
      "preLaunchTask": "make-debug",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "stopAtEntry": true,
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "moduleName",
      "type": "promptString",
      "description": "Enter module name for debug",
      "default": "YourModuleName"
    }
  ]
}
